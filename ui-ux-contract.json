{
  "contract_version": 1,
  "product": {
    "name": "AI Dev Template Configurator",
    "goal": "Generate a valid .ai-dev-template.config.json for AI-dev-template repositories."
  },
  "design_principles": [
    "Use a step-by-step wizard.",
    "Ask only questions that affect the generated config.",
    "Hide irrelevant questions when a parent feature is disabled.",
    "Prefer fixed answer options over free text wherever possible.",
    "Show a live config summary and a final JSON preview."
  ],
  "output": {
    "format": "json",
    "target_file_name": ".ai-dev-template.config.json",
    "schema_root": "ai_dev_template_config"
  },
  "screens": [
    {
      "id": "welcome",
      "type": "intro",
      "title": "Configure Repository Workflow",
      "description": "Set language, workflow mode, PR policy, and artifact persistence for a new AI Dev Template repository.",
      "primary_action": "Start configuration"
    },
    {
      "id": "language",
      "type": "form",
      "title": "Language",
      "description": "Choose the language used by repository artifacts. GitHub labels remain in English.",
      "fields": [
        {
          "id": "language.repository",
          "component": "segmented_control",
          "label": "Repository language",
          "required": true,
          "default": "en",
          "help_text": "Docs, README, architecture decisions, GitHub Issues.",
          "options": [
            { "value": "en", "label": "English" },
            { "value": "ru", "label": "Russian" }
          ]
        },
        {
          "id": "language.workflow",
          "component": "segmented_control",
          "label": "Workflow language",
          "required": true,
          "default": "en",
          "help_text": "PR titles and descriptions, review comments, commit messages.",
          "options": [
            { "value": "en", "label": "English" },
            { "value": "ru", "label": "Russian" }
          ]
        }
      ]
    },
    {
      "id": "execution_mode",
      "type": "form",
      "title": "Execution Mode",
      "description": "Choose how autonomous the agent should be.",
      "fields": [
        {
          "id": "workflow.execution_mode",
          "component": "card_radio_group",
          "label": "Execution mode",
          "required": true,
          "default": "autonomous",
          "options": [
            {
              "value": "autonomous",
              "label": "Autonomous",
              "description": "Continuous delivery loop: after closing each task the agent immediately picks the next one. Stops only on a real blocker, configured checkpoint, or empty backlog."
            },
            {
              "value": "staged",
              "label": "Staged",
              "description": "Agent pauses between work stages and waits for explicit human confirmation before continuing."
            }
          ]
        }
      ]
    },
    {
      "id": "architecture",
      "type": "form",
      "title": "Frontend Architecture",
      "description": "Choose whether the template should treat Feature-Sliced Design as the default frontend architecture.",
      "fields": [
        {
          "id": "architecture.use_fsd",
          "component": "card_radio_group",
          "label": "Use Feature-Sliced Design (FSD)",
          "required": true,
          "default": true,
          "help_text": "Controls whether generated guidance and project structure should explicitly target FSD layers and boundaries for frontend code.",
          "options": [
            {
              "value": true,
              "label": "Enabled",
              "description": "Frontend guidance assumes FSD and recommends keeping code in FSD layers with explicit boundaries."
            },
            {
              "value": false,
              "label": "Disabled",
              "description": "The template does not impose FSD and allows the team to use another frontend structure."
            }
          ]
        }
      ]
    },
    {
      "id": "pull_requests",
      "type": "form",
      "title": "Pull Requests",
      "description": "Choose whether tasks in this repository use a pull-request workflow.",
      "fields": [
        {
          "id": "pull_requests.enabled",
          "component": "card_radio_group",
          "label": "Use pull requests",
          "required": true,
          "default": true,
          "options": [
            {
              "value": true,
              "label": "Yes",
              "description": "Use branch, PR, review, and merge workflow."
            },
            {
              "value": false,
              "label": "No",
              "description": "Work is tracked through docs, issues, and commits without PR stages."
            }
          ]
        },
        {
          "id": "pull_requests.creation_mode",
          "component": "segmented_control",
          "label": "PR policy for tasks",
          "required": true,
          "default": "for_significant_tasks",
          "visibility": {
            "field": "pull_requests.enabled",
            "operator": "equals",
            "value": true
          },
          "options": [
            {
              "value": "for_every_task",
              "label": "Every task",
              "description": "Create a separate branch and PR for every task."
            },
            {
              "value": "for_significant_tasks",
              "label": "Significant tasks only",
              "description": "Use PRs only for significant tasks. When branch protection is active, non-significant tasks also get a PR — but without review, merged automatically after green checks."
            },
            {
              "value": "manual_per_task",
              "label": "Decide per task",
              "description": "Use a PR for a task only after an explicit human decision."
            }
          ]
        }
      ]
    },
    {
      "id": "review_merge",
      "type": "form",
      "title": "Review And Merge",
      "description": "Review policy is only needed when pull requests are enabled.",
      "fields": [
        {
          "id": "pull_requests.review.required",
          "component": "card_radio_group",
          "label": "Require review",
          "required": true,
          "default": true,
          "visibility": {
            "field": "pull_requests.enabled",
            "operator": "equals",
            "value": true
          },
          "options": [
            {
              "value": true,
              "label": "Yes",
              "description": "A PR cannot be merged until review policy is satisfied."
            },
            {
              "value": false,
              "label": "No",
              "description": "PRs may exist, but formal review is optional."
            }
          ]
        },
        {
          "id": "pull_requests.review.reviewers",
          "component": "segmented_control",
          "label": "Reviewer type",
          "required": true,
          "default": "human",
          "visibility": {
            "field": "pull_requests.review.required",
            "operator": "equals",
            "value": true
          },
          "options": [
            { "value": "human", "label": "Human" },
            { "value": "ai", "label": "AI" },
            { "value": "both", "label": "Both" }
          ]
        },
        {
          "id": "ai_reviewer_note",
          "component": "info_banner",
          "label": "ai_reviewer_note",
          "required": false,
          "default": "",
          "visibility": {
            "field": "pull_requests.review.reviewers",
            "operator": "equals",
            "value": "ai"
          }
        },
        {
          "id": "pull_requests.merge.squash_commits",
          "component": "checkbox",
          "label": "Squash commits before merge",
          "required": true,
          "default": true,
          "help_text": "If enabled, multiple commits from the task branch are combined into one before merge.",
          "visibility": {
            "field": "pull_requests.enabled",
            "operator": "equals",
            "value": true
          }
        },
        {
          "id": "pull_requests.merge.integration_method",
          "component": "segmented_control",
          "label": "Branch integration method",
          "required": true,
          "default": "merge",
          "visibility": {
            "field": "pull_requests.enabled",
            "operator": "equals",
            "value": true
          },
          "options": [
            { "value": "merge", "label": "Merge commit" },
            { "value": "rebase", "label": "Rebase" }
          ]
        },
        {
          "id": "pull_requests.merge.require_green_checks",
          "component": "switch",
          "label": "Require green checks before merge",
          "required": true,
          "default": true,
          "visibility": {
            "field": "pull_requests.enabled",
            "operator": "equals",
            "value": true
          }
        },
        {
          "id": "pull_requests.merge.allow_agent_self_merge",
          "component": "switch",
          "label": "Allow agent self-merge",
          "required": true,
          "default": false,
          "visibility": {
            "field": "pull_requests.review.reviewers",
            "operator": "equals",
            "value": "ai"
          }
        },
        {
          "id": "branch_protection_note",
          "component": "info_banner",
          "label": "branch_protection_note",
          "required": false,
          "default": "",
          "visibility": {
            "all_of": [
              {
                "field": "pull_requests.enabled",
                "operator": "equals",
                "value": true
              },
              {
                "field": "pull_requests.review.required",
                "operator": "equals",
                "value": true
              }
            ]
          }
        },
        {
          "id": "pull_requests.merge.agent_configure_branch_protection",
          "component": "switch",
          "label": "Let agent configure branch protection",
          "required": true,
          "default": false,
          "visibility": {
            "all_of": [
              {
                "field": "pull_requests.enabled",
                "operator": "equals",
                "value": true
              },
              {
                "field": "pull_requests.review.required",
                "operator": "equals",
                "value": true
              }
            ]
          }
        },
        {
          "id": "branch_protection_creation_mode_warning",
          "component": "info_banner",
          "label": "branch_protection_creation_mode_warning",
          "required": false,
          "default": "",
          "visibility": {
            "all_of": [
              {
                "field": "pull_requests.merge.agent_configure_branch_protection",
                "operator": "equals",
                "value": true
              },
              {
                "field": "pull_requests.creation_mode",
                "operator": "not_equals",
                "value": "for_every_task"
              }
            ]
          }
        }
      ]
    },
    {
      "id": "project_map",
      "type": "form",
      "title": "Project Map",
      "description": "The agent can maintain a structured map of the project file tree to simplify navigation across sessions.",
      "fields": [
        {
          "id": "project_map.enabled",
          "component": "switch",
          "label": "Maintain project map",
          "required": true,
          "default": true,
          "help_text": "If enabled, the agent creates and updates docs/project-map.md — a file tree with descriptions of each folder and key file."
        }
      ]
    },
    {
      "id": "github_permissions",
      "type": "summary",
      "title": "GitHub Token Requirements",
      "description": "Show which token scopes the repository expects. This is explanatory and not user-editable in the first version.",
      "display_blocks": [
        {
          "title": "Required scopes",
          "items": ["repo", "project"]
        },
        {
          "title": "Recommended scopes",
          "items": ["read:org", "workflow"]
        },
        {
          "title": "Notes",
          "items": [
            "Scopes do not guarantee repository-specific write access.",
            "Branch protection and project write permissions must still be checked separately."
          ]
        }
      ]
    },
    {
      "id": "review",
      "type": "review",
      "title": "Review Configuration",
      "description": "Show a human-readable summary before generating the final JSON.",
      "sections": [
        "Language",
        "Execution mode",
        "Frontend architecture",
        "Pull requests",
        "Review and merge",
        "Project map",
        "GitHub token requirements"
      ],
      "primary_action": "Generate config"
    },
    {
      "id": "result",
      "type": "result",
      "title": "Configuration Generated",
      "description": "Display the final JSON and provide copy and download actions.",
      "actions": [
        "Copy JSON",
        "Download .ai-dev-template.config.json",
        "Start over"
      ]
    }
  ],
  "generated_json_template": {
    "config_version": 1,
    "architecture": {
      "use_fsd": "{{architecture.use_fsd}}"
    },
    "language": {
      "documentation": "{{language.documentation}}",
      "issues": "{{language.issues}}",
      "pull_requests": "{{language.pull_requests}}",
      "comments": "{{language.comments}}",
      "commits": "{{language.commits}}",
      "labels": "en",
      "agent_instructions": "en"
    },
    "workflow": {
      "execution_mode": "{{workflow.execution_mode}}",
      "issue_tracking": "github_issues",
      "project_tracking": "github_project"
    },
    "pull_requests": {
      "enabled": "{{pull_requests.enabled}}",
      "creation_mode": "{{pull_requests.creation_mode}}",
      "review": {
        "required": "{{pull_requests.review.required}}",
        "reviewers": "{{pull_requests.review.reviewers}}"
      },
      "merge": {
        "squash_commits": "{{pull_requests.merge.squash_commits}}",
        "integration_method": "{{pull_requests.merge.integration_method}}",
        "require_green_checks": "{{pull_requests.merge.require_green_checks}}",
        "allow_agent_self_merge": "{{pull_requests.merge.allow_agent_self_merge}}",
        "agent_configure_branch_protection": "{{pull_requests.merge.agent_configure_branch_protection}}"
      }
    },
    "project_map": {
      "enabled": "{{project_map.enabled}}"
    }
  }
}
